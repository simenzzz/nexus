# SurrealDB
# Use ws://surrealdb:8000 when running via Docker Compose
# Use ws://localhost:8000 when running locally
SURREAL_URL=ws://surrealdb:8000
SURREAL_NS=nexus
SURREAL_DB=nexus
SURREAL_USER=root
SURREAL_PASS=root

# JWT
JWT_SECRET=change-me-to-a-random-64-char-string
ACCESS_TOKEN_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=7

# Redis
REDIS_URL=redis://redis:6379

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=3001

# Security — set to true in production
SECURE_COOKIES=false
# CORS allowed origin
CORS_ORIGIN=http://localhost:3000

# Client (set by docker-compose for the client service)
PUBLIC_API_URL=http://localhost:3001
PUBLIC_WS_URL=ws://localhost:3001/ws
