# =========================================================================
# Nexus environment configuration.
# Copy to `.env` and fill in real values. THIS FILE IS NOT SAFE FOR PROD.
# Any value below that contains "change-me" or matches a known weak default
# (root, etc.) will cause the server to refuse to start in production mode.
# =========================================================================

# ─── Environment flag ────────────────────────────────────────────────────
# development | production
# In production mode the server hard-fails on weak credentials, missing
# CORS_ORIGIN, SECURE_COOKIES=false, etc.
NEXUS_ENV=development

# ─── SurrealDB ───────────────────────────────────────────────────────────
# Container DNS for compose; localhost when running natively.
SURREAL_URL=ws://surrealdb:8000
SURREAL_NS=nexus
SURREAL_DB=nexus
# REQUIRED to be non-default + >= 16 chars in production.
SURREAL_USER=root
SURREAL_PASS=root

# ─── JWT ─────────────────────────────────────────────────────────────────
# REQUIRED to be >= 32 chars. Generate via: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-string-via-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=7

# ─── Redis ───────────────────────────────────────────────────────────────
# Required by docker-compose for `redis-server --requirepass`. Pick a
# random value in production: `openssl rand -hex 24`.
REDIS_PASSWORD=devpassword-change-me
REDIS_URL=redis://:devpassword-change-me@redis:6379

# ─── Server bind ─────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=3001
RUST_LOG=info

# ─── Cookie + CORS hardening ─────────────────────────────────────────────
# MUST be true in production. Refresh and CSRF cookies depend on this for
# the Secure attribute.
SECURE_COOKIES=false
# Origin allowed by CORS. In production this MUST be set explicitly to
# your public URL (e.g. https://app.example.com); no localhost fallback.
CORS_ORIGIN=http://localhost:3000

# ─── Client dev overrides ────────────────────────────────────────────────
# Local Docker/dev uses the backend's direct localhost port. Production uses
# same-origin /api and /ws through Caddy, so docker-compose.prod.yml clears
# these values.
PUBLIC_API_URL=http://localhost:3001
PUBLIC_WS_URL=ws://localhost:3001/ws

# ─── Prod-only (used by docker-compose.prod.yml + Caddyfile) ─────────────
# Public hostname; Caddy auto-provisions TLS for this domain.
DOMAIN=app.example.com
ACME_EMAIL=admin@example.com
# Pin image tags if pulling from a registry.
SERVER_IMAGE=nexus-server:latest
CLIENT_IMAGE=nexus-client:latest
